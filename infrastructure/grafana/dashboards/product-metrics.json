{
  "title": "Sellevate Product Metrics",
  "uid": "sellevate-product",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Users Online",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "app_users_online{job=~\"sallevate-backend|sellevate-analytics\"}",
          "legendFormat": "online"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Visits Today",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "increase(app_authenticated_requests_total{job=~\"sallevate-backend|sellevate-analytics\"}[1d])",
          "legendFormat": "today"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Visits This Week",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "increase(app_authenticated_requests_total{job=~\"sallevate-backend|sellevate-analytics\"}[7d])",
          "legendFormat": "7d"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Registrations Today",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "increase(app_registrations_total{job=~\"sallevate-backend|sellevate-analytics\"}[1d])",
          "legendFormat": "today"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Page View Rate (per page)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (page) (rate(app_page_views_total{job=~\"sallevate-backend|sellevate-analytics\"}[5m]))",
          "legendFormat": "{{page}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Logins Rate (per method)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (method) (rate(app_logins_total{job=~\"sallevate-backend|sellevate-analytics\"}[5m]))",
          "legendFormat": "{{method}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "bargauge",
      "title": "Top Events (last 24h)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "orientation": "horizontal", "displayMode": "gradient" },
      "targets": [
        {
          "expr": "topk(10, sum by (event) (increase(app_events_total{job=~\"sallevate-backend|sellevate-analytics\"}[1d])))",
          "legendFormat": "{{event}}",
          "instant": true
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Daily Active (visits proxy, 1d rolling)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "increase(app_authenticated_requests_total{job=~\"sallevate-backend|sellevate-analytics\"}[1d])",
          "legendFormat": "authenticated requests / 1d"
        }
      ]
    }
  ],
  "__inputs": [
    { "name": "DS_PROMETHEUS", "type": "datasource", "pluginId": "prometheus" }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ]
}
