{
  "title": "Sellevate Kafka & Service Health",
  "uid": "sellevate-kafka-health",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Kafka Brokers Up",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "kafka_brokers",
          "legendFormat": "brokers"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Kafka Exporter Up",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }
          ]
        }
      },
      "targets": [
        {
          "expr": "up{job=\"kafka-exporter\"}",
          "legendFormat": "exporter"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Consumer Lag",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(kafka_consumergroup_lag)",
          "legendFormat": "lag"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Scraped Service Targets Up",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "count(up{job=~\"sellevate-.*\"} == 1)",
          "legendFormat": "up"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Consumer Lag by Group",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (consumergroup) (kafka_consumergroup_lag)",
          "legendFormat": "{{consumergroup}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Consumer Lag by Topic",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (topic) (kafka_consumergroup_lag)",
          "legendFormat": "{{topic}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Topic Message Production Rate",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (topic) (rate(kafka_topic_partition_current_offset[5m]))",
          "legendFormat": "{{topic}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Service & Exporter Targets",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "up{job=~\"sellevate-.*|kafka-exporter\"}",
          "legendFormat": "{{job}} ({{instance}})",
          "instant": true,
          "format": "table"
        }
      ]
    }
  ]
}
