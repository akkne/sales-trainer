  },
  "Storage": {
    "S3": {
      "Endpoint": "http://minio:9000",
      "Bucket": "salestrainer-avatars",
      "Region": "us-east-1",
      "ForcePathStyle": true,
      "AccessKey": "INJECTED_FROM_ENV",
      "SecretKey": "INJECTED_FROM_ENV"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
