{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Loki": {
      "Url": "http://loki:3100"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "INJECTED_FROM_ENV"
  },
  "Kafka": {
    "BootstrapServers": "kafka:29092",
    "ConsumerGroupId": "identity-service"
  },
  "Jwt": {
    "Key": "INJECTED_FROM_ENV",
    "Issuer": "sallevate",
    "Audience": "sallevate"
  },
  "Frontend": {
    "Url": "http://localhost:3000"
  },
  "Google": {
    "ClientId": "INJECTED_FROM_ENV"
  },
  "MailerSend": {
    "ApiToken": "INJECTED_FROM_ENV",
