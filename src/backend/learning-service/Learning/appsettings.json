{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Loki": {
      "Url": "http://loki:3100"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "INJECTED_FROM_ENV",
    "Redis": "redis:6379"
  },
  "Kafka": {
    "BootstrapServers": "kafka:29092",
    "ConsumerGroupId": "learning-service"
  },
  "Jwt": {
    "Key": "INJECTED_FROM_ENV",
    "Issuer": "sallevate",
    "Audience": "sallevate"
  },
  "AiService": {
    "BaseUrl": "http://ai:8080",
    "EvaluatePath": "/ai/evaluate"
  },
  "OpenAI": {
    "ApiKey": "INJECTED_FROM_ENV",
    "BaseUrl": "https://api.openai.com",
    "ChatCompletionsPath": "/v1/chat/completions"
  },
  "YandexTts": {
    "ApiKey": "INJECTED_FROM_ENV",
    "BaseUrl": "https://tts.api.cloud.yandex.net",
    "Voice": "marina",
    "Lang": "ru-RU",
    "Speed": "1.2"
  },
  "Voice": {
    "Enabled": true,
    "TtsProvider": "yandex",
    "VadSilenceMs": 450,
    "MaxRecordingSeconds": 60,
    "DailyLimitMinutes": 30,
    "MonthlyLimitMinutes": 300
  },
  "Frontend": {
    "Url": "http://localhost:3000"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
