{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Loki": {
      "Url": "http://loki:3100"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "INJECTED_FROM_ENV",
    "Mongo": "mongodb://mongo:27017",
    "Redis": "redis:6379"
  },
  "Mongo": {
    "DatabaseName": "sallevate"
  },
  "Kafka": {
    "BootstrapServers": "kafka:29092",
    "ConsumerGroupId": "social-service"
  },
  "Jwt": {
    "Key": "INJECTED_FROM_ENV",
    "Issuer": "sallevate",
    "Audience": "sallevate"
  },
  "Frontend": {
    "Url": "http://localhost:3000"
  },
  "Storage": {
    "S3": {
      "Endpoint": "http://minio:9000",
      "Bucket": "sellevate-social",
      "AccessKey": "INJECTED_FROM_ENV",
      "SecretKey": "INJECTED_FROM_ENV",
      "Region": "us-east-1",
      "ForcePathStyle": true
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
