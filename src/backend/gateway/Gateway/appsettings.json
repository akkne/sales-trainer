{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    },
    "Loki": {
      "Url": "http://loki:3100"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "INJECTED_FROM_ENV",
    "Issuer": "sallevate",
    "Audience": "sallevate"
  },
  "ReverseProxy": {
    "Routes": {
      "analytics-tracking": {
        "ClusterId": "analytics",
        "Match": {
          "Path": "/tracking/{**catch-all}"
        }
      },
      "ai-dialog": {
        "ClusterId": "ai",
        "Match": {
          "Path": "/dialog/{**catch-all}"
        }
      },
      "ai-transcription": {
        "ClusterId": "ai",
        "Match": {
          "Path": "/transcription/{**catch-all}"
        }
      },
      "ai-admin-dialog": {
        "ClusterId": "ai",
        "Match": {
          "Path": "/admin/dialog/{**catch-all}"
        }
      },
      "ai-admin-voice": {
        "ClusterId": "ai",
        "Match": {
          "Path": "/admin/voice/{**catch-all}"
        }
      },
      "monolith-catch-all": {
        "ClusterId": "monolith",
        "Match": {
          "Path": "{**catch-all}"
        }
      }
    },
    "Clusters": {
      "monolith": {
        "Destinations": {
          "d1": {
            "Address": "http://backend:8080/"
          }
        }
      },
      "ai": {
        "Destinations": {
          "d1": {
            "Address": "http://ai:8080/"
          }
        }
      },
      "analytics": {
        "Destinations": {
          "d1": {
            "Address": "http://analytics:8080/"
          }
        }
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
