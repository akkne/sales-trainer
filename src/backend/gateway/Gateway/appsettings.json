{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    },
    "Loki": {
      "Url": "http://loki:3100"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "INJECTED_FROM_ENV",
    "Issuer": "sallevate",
    "Audience": "sallevate"
  },
  "ReverseProxy": {
    "Routes": {
      "analytics-tracking": {
        "ClusterId": "analytics",
        "Match": {
          "Path": "/tracking/{**catch-all}"
        }
      },
      "ai-dialog": {
        "ClusterId": "ai",
        "Match": {
          "Path": "/dialog/{**catch-all}"
        }
      },
      "ai-transcription": {
        "ClusterId": "ai",
        "Match": {
          "Path": "/transcription/{**catch-all}"
        }
      },
      "ai-admin-dialog": {
        "ClusterId": "ai",
        "Match": {
          "Path": "/admin/dialog/{**catch-all}"
        }
      },
      "ai-admin-voice": {
        "ClusterId": "ai",
        "Match": {
          "Path": "/admin/voice/{**catch-all}"
        }
      },
      "notification-notifications": {
        "ClusterId": "notification",
        "Match": {
          "Path": "/notifications/{**catch-all}"
        }
      },
      "notification-notifications-root": {
        "ClusterId": "notification",
        "Match": {
          "Path": "/notifications"
        }
      },
      "identity-auth": {
        "ClusterId": "identity",
        "Match": { "Path": "/auth/{**catch-all}" }
      },
      "identity-demo": {
        "ClusterId": "identity",
        "Match": { "Path": "/demo/{**catch-all}" }
      },
      "identity-profile": {
        "ClusterId": "identity",
        "Match": { "Path": "/profile/{**catch-all}" }
      },
      "identity-profile-root": {
        "ClusterId": "identity",
        "Match": { "Path": "/profile" }
      },
      "identity-onboarding": {
        "ClusterId": "identity",
        "Match": { "Path": "/onboarding/{**catch-all}" }
      },
      "identity-onboarding-root": {
        "ClusterId": "identity",
        "Match": { "Path": "/onboarding" }
      },
      "identity-avatars": {
        "ClusterId": "identity",
        "Match": { "Path": "/avatars/{**catch-all}" }
      },
      "identity-avatars-root": {
        "ClusterId": "identity",
        "Match": { "Path": "/avatars" }
      },
      "gamification-progress": {
        "ClusterId": "gamification",
        "Match": { "Path": "/gamification/{**catch-all}" }
      },
      "gamification-league": {
        "ClusterId": "gamification",
        "Match": { "Path": "/league" }
      },
      "gamification-league-tree": {
        "ClusterId": "gamification",
        "Match": { "Path": "/league/{**catch-all}" }
      },
      "gamification-achievements": {
        "ClusterId": "gamification",
        "Match": { "Path": "/profile/achievements" }
      },
      "gamification-achievements-tree": {
        "ClusterId": "gamification",
        "Match": { "Path": "/profile/achievements/{**catch-all}" }
      },
      "gamification-admin-gamification": {
        "ClusterId": "gamification",
        "Match": { "Path": "/admin/gamification/{**catch-all}" }
      },
      "gamification-admin-leagues": {
        "ClusterId": "gamification",
        "Match": { "Path": "/admin/leagues/{**catch-all}" }
      },
      "gamification-admin-leagues-root": {
        "ClusterId": "gamification",
        "Match": { "Path": "/admin/leagues" }
      },
      "monolith-catch-all": {
        "ClusterId": "monolith",
        "Match": {
          "Path": "{**catch-all}"
        }
      }
    },
    "Clusters": {
      "gamification": {
        "Destinations": {
          "d1": {
            "Address": "http://gamification:8080/"
          }
        }
      },
      "identity": {
        "Destinations": {
          "d1": {
            "Address": "http://identity:8080/"
          }
        }
      },
      "monolith": {
        "Destinations": {
          "d1": {
            "Address": "http://backend:8080/"
          }
        }
      },
      "ai": {
        "Destinations": {
          "d1": {
            "Address": "http://ai:8080/"
          }
        }
      },
      "analytics": {
        "Destinations": {
          "d1": {
            "Address": "http://analytics:8080/"
          }
        }
      },
      "notification": {
        "Destinations": {
          "d1": {
            "Address": "http://notification:8080/"
          }
        }
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
