{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    },
    "Loki": {
      "Url": "http://loki:3100"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "INJECTED_FROM_ENV",
    "Issuer": "sallevate",
    "Audience": "sallevate"
  },
  "ReverseProxy": {
    "Routes": {
      "identity-auth": {
        "ClusterId": "identity",
        "Match": { "Path": "/auth/{**catch-all}" }
      },
      "identity-demo": {
        "ClusterId": "identity",
        "Match": { "Path": "/demo/{**catch-all}" }
      },
      "identity-profile": {
        "ClusterId": "identity",
        "Match": { "Path": "/profile/{**catch-all}" }
      },
      "identity-profile-root": {
        "ClusterId": "identity",
        "Match": { "Path": "/profile" }
      },
      "identity-onboarding": {
        "ClusterId": "identity",
        "Match": { "Path": "/onboarding/{**catch-all}" }
      },
      "identity-onboarding-root": {
        "ClusterId": "identity",
        "Match": { "Path": "/onboarding" }
      },
      "identity-avatars": {
        "ClusterId": "identity",
        "Match": { "Path": "/avatars/{**catch-all}" }
      },
      "identity-avatars-root": {
        "ClusterId": "identity",
        "Match": { "Path": "/avatars" }
      },
      "monolith-catch-all": {
        "ClusterId": "monolith",
        "Match": {
          "Path": "{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity": {
        "Destinations": {
          "d1": {
            "Address": "http://identity:8080/"
          }
        }
      },
      "monolith": {
        "Destinations": {
          "d1": {
            "Address": "http://backend:8080/"
          }
        }
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
