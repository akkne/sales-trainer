{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Loki": {
      "Url": "http://loki:3100"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "INJECTED_FROM_ENV",
    "Mongo": "mongodb://mongo:27017",
    "Redis": "redis:6379"
  },
  "Mongo": {
    "DatabaseName": "sallevate"
  },
  "Jwt": {
    "Key": "INJECTED_FROM_ENV",
    "Issuer": "sallevate",
    "Audience": "sallevate"
  },
  "Frontend": {
    "Url": "http://localhost:3000"
  },
  "OpenAI": {
    "ApiKey": "INJECTED_FROM_ENV",
    "BaseUrl": "https://api.openai.com",
    "ChatCompletionsPath": "/v1/chat/completions",
    "ChatModel": "gpt-4.1-nano",
    "FeedbackModel": "gpt-4.1",
    "FreeTextModel": "gpt-4o-mini",
    "OpenQuestionModel": "gpt-4.1",
    "MaxTokensChat": 500,
    "MaxTokensFeedback": 1500,
    "MaxTokensFreeText": 300,
    "MaxTokensOpenQuestion": 300
  },
  "ExerciseEvaluation": {
    "PassingScoreThreshold": 7
  },
  "Gamification": {
    "DailyXpGoal": 100
  },
  "Google": {
    "ClientId": "INJECTED_FROM_ENV"
  },
  "MailerSend": {
    "ApiToken": "INJECTED_FROM_ENV",
    "BaseUrl": "https://api.mailersend.com",
    "FromEmail": "INJECTED_FROM_ENV",
    "FromName": "Sellevate"
  },
  "EmailVerification": {
    "CodeLength": 6,
    "CodeLifetimeMinutes": 10,
    "MaximumVerificationAttempts": 5,
    "ResendCooldownSeconds": 60
  },
  "SuperAdmin": {
    "Email": "INJECTED_FROM_ENV",
    "Password": "INJECTED_FROM_ENV",
    "DisplayName": "INJECTED_FROM_ENV"
  },
  "Deepgram": {
    "ApiKey": "INJECTED_FROM_ENV",
    "Model": "nova-3",
    "Language": "ru",
    "SmartFormat": true,
    "Punctuate": true
  },
  "YandexTts": {
    "ApiKey": "INJECTED_FROM_ENV",
    "BaseUrl": "https://tts.api.cloud.yandex.net",
    "Voice": "marina",
    "Lang": "ru-RU",
    "Speed": "1.2"
  },
  "Voice": {
    "Enabled": true,
    "TtsProvider": "yandex",
    "VadSilenceMs": 450,
    "MaxRecordingSeconds": 60,
    "DailyLimitMinutes": 30,
    "MonthlyLimitMinutes": 300
  },
  "Storage": {
    "S3": {
      "Endpoint": "http://localhost:9000",
      "Bucket": "salestrainer-avatars",
      "Region": "us-east-1",
      "ForcePathStyle": true,
      "AccessKey": "INJECTED_FROM_ENV",
      "SecretKey": "INJECTED_FROM_ENV"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
