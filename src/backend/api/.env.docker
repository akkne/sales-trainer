# Backend service config for docker-compose (no secrets here).
# Secrets are injected from the root .env via docker-compose.yml.
# Non-environment-specific defaults live in appsettings.json.
ASPNETCORE_ENVIRONMENT=Development
ConnectionStrings__Mongo=mongodb://mongo:27017
ConnectionStrings__Redis=redis:6379
Jwt__Issuer=sallevate
Jwt__Audience=sallevate
Frontend__Url=http://localhost:3000
Logging__Loki__Url=http://loki:3100
