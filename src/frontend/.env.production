# Frontend service config (no secrets here).
# NEXT_PUBLIC_* vars are baked in at build time (npm run build inside Docker).
# Secrets (NEXT_PUBLIC_GOOGLE_CLIENT_ID) are passed as build args from the root .env.
NEXT_PUBLIC_API_URL=https://api.sellevate.site
# Runtime-only (injected by docker-compose env_file)
LOKI_URL=http://loki:3100
