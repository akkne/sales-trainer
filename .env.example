# Copy this file to .env and fill in real values.
# docker-compose reads .env automatically.
# Only secrets & infrastructure credentials belong here.
# Service-specific (non-secret) config lives in:
#   backend:  src/backend/api/appsettings.json
#   frontend: src/frontend/.env.production

# --- Infrastructure ---
POSTGRES_DB=sallevate
POSTGRES_USER=st
POSTGRES_PASSWORD=CHANGE_ME
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# --- Frontend / CORS ---
# Comma-separated list of allowed browser origins for the backend CORS policy.
# Include localhost for dev and the production domain for the deployed frontend.
FRONTEND_URL=http://localhost:3000,https://sellevate.site

# --- Reverse proxy (docker-compose.prod.yml / Traefik) ---
# Base domain. Traefik routes:  DOMAIN -> frontend, api.DOMAIN -> backend,
# grafana.DOMAIN -> Grafana. Change this single value to rehost on another domain.
DOMAIN=sellevate.site
# Email for Let's Encrypt certificate notifications (used only in production).
ACME_EMAIL=you@example.com

# --- Auth ---
JWT_KEY=CHANGE_ME_AT_LEAST_32_CHARS_LONG_SECRET
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=CHANGE_ME
SUPERADMIN_DISPLAY_NAME=Super Admin

# --- Email (MailerSend) ---
# Transactional email for the email-verification-by-code flow.
# Create an API token at https://app.mailersend.com (Domains -> your domain -> API tokens).
# FROM_EMAIL must belong to a domain verified in MailerSend (SPF/DKIM/DMARC configured).
# Leave the token as-is for local dev: the backend then logs the code instead of sending.
# IMPORTANT: the token value is the API token ONLY — do not append the from-email/name here
# (they have their own variables below). A token containing whitespace is rejected as malformed.
MAILERSEND_API_TOKEN=YOUR_MAILERSEND_API_TOKEN
MAILERSEND_FROM_EMAIL=noreply@yourdomain.com
MAILERSEND_FROM_NAME=Sellevate

# --- LLM (OpenAI-compatible provider) ---
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_BASE_URL=https://api.openai.com
OPENAI_CHAT_COMPLETIONS_PATH=/v1/chat/completions
# Auth style / response schema for the provider: OpenAi (Bearer, api.openai.com) or F5Ai
# (X-Auth-Token, api.f5ai.ru). Set F5Ai when OPENAI_BASE_URL points at the F5 AI gateway.
OPENAI_PROVIDER=OpenAi

# --- Speech ---
DEEPGRAM_API_KEY=YOUR_DEEPGRAM_API_KEY
# Yandex SpeechKit API key (service account, role ai.speechkit-tts.user)
YANDEX_TTS_API_KEY=YOUR_YANDEX_API_KEY

# --- Object Storage (MinIO / S3) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# For local dev the backend reads these from appsettings.Development.json.
# In full-Docker stack these env vars override appsettings via docker-compose.yml.
Storage__S3__Endpoint=http://minio:9000
Storage__S3__AccessKey=minioadmin
Storage__S3__SecretKey=minioadmin
Storage__S3__Bucket=salestrainer-avatars

# ===========================================================================
# OPERATIONAL TUNABLES (optional)
# ---------------------------------------------------------------------------
# Every line below is OPTIONAL — docker-compose already falls back to the
# in-code default shown after ":-". Uncomment + set a value to change behaviour
# in production WITHOUT editing code or rebuilding (ASP.NET binds Section__Key).
# ===========================================================================

# --- LLM (ai-service + learning-service) ---
#OPENAI_DIALOG_MODEL=gpt-4.1
#OPENAI_OPEN_QUESTION_MODEL=gpt-4.1
#OPENAI_DIALOG_TEMPERATURE=0.7
#OPENAI_MAX_TOKENS_DIALOG=500
#OPENAI_MAX_TOKENS_FEEDBACK=1500
#OPENAI_MAX_TOKENS_OPEN_QUESTION=300

# --- Speech-to-text (Whisper, ai-service) ---
#WHISPER_MODEL=whisper-1
#WHISPER_LANGUAGE=ru

# --- Text-to-speech + voice (ai-service + learning-service) ---
#TTS_PROVIDER=yandex            # yandex is the only supported provider
#VOICE_ENABLED=true
#VOICE_DAILY_LIMIT_MINUTES=30
#VOICE_MONTHLY_LIMIT_MINUTES=300
#YANDEX_TTS_VOICE=marina
#YANDEX_TTS_LANG=ru-RU
#YANDEX_TTS_SPEED=1.2

# --- Auth / tokens (identity-service) ---
#JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
#JWT_REFRESH_TOKEN_LIFETIME_DAYS=30
#JWT_DEMO_TOKEN_LIFETIME_HOURS=2

# --- Email verification (identity-service) ---
#EMAIL_VERIFICATION_CODE_LIFETIME_MINUTES=10
#EMAIL_VERIFICATION_MAX_ATTEMPTS=5
#EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60

# --- Notifications (notification-service) ---
#NOTIFICATION_INBOX_CAPACITY=100
#NOTIFICATION_RETENTION_DAYS=30

# --- Gamification (gamification-service) ---
#GAMIFICATION_STREAK_TIMEZONE=UTC
