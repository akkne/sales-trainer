# Copy this file to .env and fill in real values.
# docker-compose reads .env automatically.
# Only secrets & infrastructure credentials belong here.
# Service-specific (non-secret) config lives in:
#   backend:  src/backend/api/appsettings.json
#   frontend: src/frontend/.env.production

# --- Infrastructure ---
POSTGRES_DB=sallevate
POSTGRES_USER=st
POSTGRES_PASSWORD=CHANGE_ME
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# --- Auth ---
JWT_KEY=CHANGE_ME_AT_LEAST_32_CHARS_LONG_SECRET
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=CHANGE_ME
SUPERADMIN_DISPLAY_NAME=Super Admin

# --- LLM (OpenAI-compatible provider) ---
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_BASE_URL=https://api.openai.com
OPENAI_CHAT_COMPLETIONS_PATH=/v1/chat/completions

# --- Speech ---
DEEPGRAM_API_KEY=YOUR_DEEPGRAM_API_KEY
# Yandex SpeechKit API key (service account, role ai.speechkit-tts.user)
YANDEX_TTS_API_KEY=YOUR_YANDEX_API_KEY
